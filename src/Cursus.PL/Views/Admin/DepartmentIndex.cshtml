@model IEnumerable<Department>

@{
    ViewData["Title"] = "Department Management";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Department Management</h1>
    <a asp-action="DepartmentCreate" class="btn btn-primary">Create Department</a>
</div>

<partial name="_AdminAlerts" />

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>University</th>
                <th>Total Credits</th>
                <th>Min GPA</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.University?.Name</td>
                    <td>@item.TotalCreditsRequired</td>
                    <td>@item.MinGpaForGraduation</td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge text-bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">Inactive</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="DepartmentEdit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        @if (item.IsActive)
                        {
                            <form asp-action="DepartmentDeactivate" asp-route-id="@item.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Deactivate this department?');">Deactivate</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>