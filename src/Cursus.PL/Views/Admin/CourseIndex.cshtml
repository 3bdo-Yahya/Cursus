@model IEnumerable<Course>

@{
    ViewData["Title"] = "Course Management";
    var includeInactive = (bool?)ViewData["IncludeInactive"] ?? false;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Course Management</h1>
    <a asp-action="CourseCreate" class="btn btn-primary">Create Course</a>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success" role="alert">@statusMessage</div>
}

<div class="mb-3">
    @if (includeInactive)
    {
        <a asp-action="CourseIndex" class="btn btn-outline-secondary btn-sm">Show Active Only</a>
    }
    else
    {
        <a asp-action="CourseIndex" asp-route-includeInactive="true" class="btn btn-outline-secondary btn-sm">Show Including Inactive</a>
    }
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>Department</th>
                <th>Credits</th>
                <th>Type</th>
                <th>Semester</th>
                <th>Pass Threshold</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Code</td>
                <td>@item.Name</td>
                <td>@item.Department?.Name</td>
                <td>@item.CreditHours</td>
                <td>@item.CourseType</td>
                <td>@item.SemesterAvailability</td>
                <td>@item.PassingGradeThreshold</td>
                <td>
                    @if (item.IsActive)
                    {
                        <span class="badge text-bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge text-bg-secondary">Inactive</span>
                    }
                </td>
                <td class="text-end">
                    <a asp-action="CourseEdit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    @if (item.IsActive)
                    {
                        <form asp-action="CourseDeactivate" asp-route-id="@item.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Deactivate this course?');">Deactivate</button>
                        </form>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>