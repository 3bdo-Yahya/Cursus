@model IEnumerable<Department>

@{
    ViewData["Title"] = "Departments";
    var searchTerm = ViewData["SearchTerm"] as string;
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Departments</h1>
        <p class="text-muted mb-0">Browse active departments and open their course catalog.</p>
    </div>
</div>

<form method="get" class="card shadow-sm mb-4">
    <div class="card-body row g-3 align-items-end">
        <div class="col-md-10">
            <label class="form-label" for="searchTerm">Search</label>
            <input id="searchTerm" name="searchTerm" value="@searchTerm" class="form-control" placeholder="Search by department or university" />
        </div>
        <div class="col-md-2 d-grid">
            <button type="submit" class="btn btn-primary">Filter</button>
        </div>
    </div>
</form>

<div class="row g-4">
    @if (Model.Any())
    {
        foreach (var department in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <h2 class="h5 mb-1">@department.Name</h2>
                        <p class="text-muted mb-3">@department.University?.Name</p>
                        <dl class="row small mb-3">
                            <dt class="col-6">Total credits</dt>
                            <dd class="col-6">@department.TotalCreditsRequired</dd>
                            <dt class="col-6">Minimum GPA</dt>
                            <dd class="col-6">@department.MinGpaForGraduation</dd>
                            <dt class="col-6">Courses</dt>
                            <dd class="col-6">@department.Courses.Count(course => course.IsActive)</dd>
                        </dl>
                        <a asp-action="Details" asp-route-id="@department.Id" class="btn btn-outline-primary mt-auto">View details</a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info mb-0">No active departments matched your search.</div>
        </div>
    }
</div>