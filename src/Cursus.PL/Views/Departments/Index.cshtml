@model IEnumerable<Department>

@{
    ViewData["Title"] = "Departments";
    var includeInactive = (bool?)ViewData["IncludeInactive"] ?? false;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Departments</h1>
    <a asp-action="Create" class="btn btn-primary">Create Department</a>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success" role="alert">@statusMessage</div>
}

<div class="mb-3">
    @if (includeInactive)
    {
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Show Active Only</a>
    }
    else
    {
        <a asp-action="Index" asp-route-includeInactive="true" class="btn btn-outline-secondary btn-sm">Show Including Inactive</a>
    }
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>University</th>
                <th>Total Credits</th>
                <th>Min GPA</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.University?.Name</td>
                <td>@item.TotalCreditsRequired</td>
                <td>@item.MinGpaForGraduation</td>
                <td>
                    @if (item.IsActive)
                    {
                        <span class="badge text-bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge text-bg-secondary">Inactive</span>
                    }
                </td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    @if (item.IsActive)
                    {
                        <form asp-action="Deactivate" asp-route-id="@item.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Deactivate this department?');">Deactivate</button>
                        </form>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
